{
  "name": "quiz-maker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "High-quality math quiz application for high school students with interactive charts, shapes, and formulas",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate-quiz-index && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "generate-quiz-index": "node scripts/generateQuizIndex.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "katex": "^0.16.11",
    "react-katex": "^3.0.1",
    "mafs": "^0.21.0",
    "zustand": "^5.0.2",
    "clsx": "^2.1.1",
    "react-markdown": "^9.0.1",
    "remark-math": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/katex": "^0.16.7",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.13.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "@vitest/ui": "^2.1.8"
  }
}
